import React from "react";

interface Props {
  chartData: Record<string, unknown>[];
}

const {{pascalCase name}} = ({ chartData}: Props) => {
  return (
    <div>
      <h3>{{titleCase name}}</h3>
      <pre>{JSON.stringify(chartData, null, 2)}</pre>
    </div>
  );
};

export default {{pascalCase name}};
